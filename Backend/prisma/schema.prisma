// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// ENUMS
// ==========================================

enum Role {
  PATIENT
  DOCTOR
  ADMIN
}

enum ConsultationStatus {
  REQUESTED
  ONGOING
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

// ==========================================
// USER & PROFILES
// ==========================================

model User {
  id              Int      @id @default(autoincrement())
  email           String   @unique
  password        String
  fullName        String
  telephoneNumber String   @unique
  role            Role     @default(PATIENT)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Profiles
  doctorProfile  DoctorProfile?
  patientProfile PatientProfile?
  adminProfile   AdminProfile?

  // Relations
  consultations       Consultation[] @relation("PatientConsultations")
  doctorConsultations Consultation[] @relation("DoctorConsultations")
  sentMessages        Message[]      @relation("UserMessages")
}

model AdminProfile {
  id     Int  @id @default(autoincrement())
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int  @unique

  isSuperAdmin Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model PatientProfile {
  id     Int      @id @default(autoincrement())
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int      @unique
  dob    DateTime @db.Date
  gender Gender?

  addresses Address[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Address {
  id               Int            @id @default(autoincrement())
  patientProfile   PatientProfile @relation(fields: [patientProfileId], references: [id], onDelete: Cascade)
  patientProfileId Int
  label            String?
  streetAddress    String
  city             String
  postalCode       String
  isDefault        Boolean        @default(false)

  @@index([patientProfileId])
}

model Specialization {
  id          Int             @id @default(autoincrement())
  name        String          @unique
  description String?         @db.Text
  doctors     DoctorProfile[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DoctorProfile {
  id               Int            @id @default(autoincrement())
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId           Int            @unique
  specialization   Specialization @relation(fields: [specializationId], references: [id])
  specializationId Int
  strNumber        String         @unique
  photoUrl         String?
  consultationFee  Float          @default(50000)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([specializationId])
}

// ==========================================
// PHARMACY & PRODUCTS
// ==========================================

model Category {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  description String?
  products    Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id          Int      @id @default(autoincrement())
  category    Category @relation(fields: [categoryId], references: [id])
  categoryId  Int
  name        String
  description String?  @db.Text
  price       Float
  stock       Int
  imageUrl    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  prescriptionItems PrescriptionItem[]

  @@index([categoryId])
}

// ==========================================
// CONSULTATION, CHAT & PRESCRIPTIONS
// ==========================================

model Consultation {
  id        Int  @id @default(autoincrement())
  patient   User @relation("PatientConsultations", fields: [patientId], references: [id])
  patientId Int
  doctor    User @relation("DoctorConsultations", fields: [doctorId], references: [id])
  doctorId  Int

  startTime DateTime?
  endTime   DateTime?
  status    ConsultationStatus @default(REQUESTED)

  // Pricing & Payment
  fee           Float         @default(0.0)
  paymentStatus PaymentStatus @default(PENDING)
  midtransToken String?
  midtransUrl   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  messages     Message[]
  prescription Prescription?

  @@index([patientId])
  @@index([doctorId])
}

model Message {
  id             Int          @id @default(autoincrement())
  consultation   Consultation @relation(fields: [consultationId], references: [id], onDelete: Cascade)
  consultationId Int
  sender         User         @relation("UserMessages", fields: [senderId], references: [id])
  senderId       Int
  content        String       @db.Text
  timestamp      DateTime     @default(now())

  @@index([consultationId])
  @@index([senderId])
}

model Prescription {
  id             Int          @id @default(autoincrement())
  consultation   Consultation @relation(fields: [consultationId], references: [id], onDelete: Cascade)
  consultationId Int          @unique
  notes          String?      @db.Text

  items PrescriptionItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PrescriptionItem {
  id             Int          @id @default(autoincrement())
  prescription   Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  prescriptionId Int
  product        Product      @relation(fields: [productId], references: [id])
  productId      Int
  dosage         String
  quantity       Int

  @@index([prescriptionId])
  @@index([productId])
}
